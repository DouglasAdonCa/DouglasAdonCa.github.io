---
import Layout from '../../layouts/Layout.astro';
import { existsSync, readdirSync } from 'node:fs';
import { join, extname } from 'node:path';
import { withBase } from '../../lib/assetPath';

const title = 'Retail Decision Intelligence | Business Intelligence Analytics';
const description =
  'Caso de proyecto: Retail Decision Intelligence para detectar pérdidas ocultas, optimizar la estrategia comercial y transformar crecimiento en rentabilidad sostenible.';

const dashboardDir = join(process.cwd(), 'public', 'images', 'projects', 'superstore-360');
const rootProjectsDir = join(process.cwd(), 'public', 'images', 'projects');
const allowedExtensions = new Set(['.png', '.jpg', '.jpeg', '.webp', '.jfif', '.jiff']);
const rootDashboardNames = new Set(['clientes', 'desempeno', 'desempeño', 'producto', 'ventas']);
const githubRawBase =
  'https://raw.githubusercontent.com/DouglasAdonCa/DouglasAdonCa.github.io/main/public/images/projects';

function readImages(dir: string, basePath: string, nameFilter?: Set<string>) {
  if (!existsSync(dir)) return [];
  return readdirSync(dir)
    .filter((name) => {
      if (!allowedExtensions.has(extname(name).toLowerCase())) return false;
      if (!nameFilter) return true;
      const baseName = name.replace(/\.[^.]+$/, '').toLowerCase();
      return nameFilter.has(baseName);
    })
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }))
    .map((name) => `${basePath}/${name}`);
}

const localDashboardShots = [
  ...readImages(dashboardDir, '/images/projects/superstore-360'),
  ...readImages(rootProjectsDir, '/images/projects', rootDashboardNames),
];

const remoteDashboardShots = [
  `${githubRawBase}/clientes.jfif`,
  `${githubRawBase}/desempe%C3%B1o.jfif`,
  `${githubRawBase}/producto.jfif`,
  `${githubRawBase}/ventas.jfif`,
];

const dashboardShots = localDashboardShots.length > 0 ? localDashboardShots : remoteDashboardShots;
---

<Layout title={title} description={description}>
  <main id="main-content" class="rdi-page">
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <a href="/#projects" class="back-link"><span aria-hidden="true">&larr;</span> Volver a proyectos</a>

          <div class="badge">RETAIL ANALYTICS • BUSINESS INTELLIGENCE</div>

          <h1>El negocio no tenía un problema de ventas. Tenía un problema de estrategia.</h1>

          <p>
            Proyecto de Retail Decision Intelligence enfocado en detectar pérdidas ocultas generadas
            por descuentos agresivos, demostrando cómo un crecimiento en revenue puede destruir
            rentabilidad cuando la estrategia comercial no está alineada al valor.
          </p>

          <div class="btn-group">
            <a href="#galeria" class="btn btn-primary">Ver Dashboard</a>
            <a href="#analisis" class="btn btn-secondary">Explorar Análisis</a>
          </div>

          <div class="stats">
            <div class="stat-card">
              <span>Revenue Total</span>
              <h3>$2.3M</h3>
            </div>

            <div class="stat-card">
              <span>Pérdida Detectada</span>
              <h3>$156K</h3>
            </div>

            <div class="stat-card">
              <span>Margen Neto</span>
              <h3>12.47%</h3>
            </div>
          </div>
        </div>

        <div class="dashboard-card">
          <div class="dashboard-top">
            <span>Retail Decision Engine</span>
            <span>Commercial Intelligence</span>
          </div>

          <div class="dashboard-box">
            <h3>Crecimiento sin rentabilidad</h3>

            <p>
              El análisis identificó que los picos de ventas coincidían con aumentos de pérdidas
              provocadas por descuentos que no generaban incremento real en demanda.
            </p>

            <div class="dashboard-grid">
              <div class="mini-box">
                <span>REVENUE GROWTH</span>
                <h4>+52%</h4>
              </div>

              <div class="mini-box">
                <span>PROFIT LOSS</span>
                <h4>$156K</h4>
              </div>

              <div class="mini-box">
                <span>LOSS SALES</span>
                <h4>19%</h4>
              </div>

              <div class="mini-box">
                <span>DEMAND</span>
                <h4>INELASTIC</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="analisis">
      <div class="container">
        <div class="badge">Problema de Negocio</div>

        <h2 class="section-title">Vender más no significa ganar más.</h2>

        <p class="section-sub">
          Aunque el negocio incrementó sus ingresos un 52% entre 2011 y 2014, el crecimiento no logró
          traducirse en valor real. El análisis reveló una estrategia comercial enfocada en volumen,
          pero desconectada de rentabilidad.
        </p>

        <div class="grid-3">
          <div class="card">
            <div class="big-number">19%</div>
            <h3>Ventas con pérdida</h3>
            <p>
              Casi una quinta parte de las transacciones destruían valor debido a descuentos
              excesivos.
            </p>
          </div>

          <div class="card">
            <div class="big-number">9%</div>
            <h3>Productos clave</h3>
            <p>Solo una pequeña parte del portafolio generaba la mayoría de las utilidades.</p>
          </div>

          <div class="card">
            <div class="big-number">48%</div>
            <h3>Clientes de valor</h3>
            <p>Menos de la mitad de los clientes concentraban el 71% del beneficio total.</p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="badge">Root Cause Analysis</div>

        <h2 class="section-title">
          El problema no estaba en la demanda. Estaba en la política de descuentos.
        </h2>

        <p class="section-sub">
          El análisis identificó un comportamiento inelástico del mercado: los descuentos agresivos no
          generaban incrementos significativos en volumen de ventas, pero sí destruían margen y
          rentabilidad.
        </p>

        <div class="grid-2">
          <div class="pricing-card loss">
            <span>Pérdida Oculta Detectada</span>

            <div class="pricing-value">$156K</div>

            <p>Valor perdido debido a descuentos que no generaban crecimiento real en demanda.</p>
          </div>

          <div class="pricing-card profit">
            <span>Impacto Potencial</span>

            <div class="pricing-value">+62%</div>

            <p>
              Incremento estimado del beneficio neto reduciendo descuentos en 10 puntos porcentuales.
            </p>
          </div>
        </div>

        <div class="quote">
          <h3>"El negocio estaba creciendo en volumen, pero destruyendo valor."</h3>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="badge">Hallazgos Estratégicos</div>

        <h2 class="section-title">
          La analítica permitió detectar pérdidas invisibles en la operación comercial.
        </h2>

        <div class="grid-3">
          <div class="card">
            <h3>Demand Inelasticity</h3>
            <p>Los descuentos no generaban incremento proporcional en ventas.</p>
          </div>

          <div class="card">
            <h3>Pricing Misalignment</h3>
            <p>La estrategia comercial priorizaba revenue sobre rentabilidad.</p>
          </div>

          <div class="card">
            <h3>Margin Erosion</h3>
            <p>Los picos de ventas coincidían con picos de pérdidas operacionales.</p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="badge">Business Impact</div>

        <h2 class="section-title">Transformando crecimiento en crecimiento rentable.</h2>

        <p class="section-sub">
          El proyecto demuestra cómo Business Intelligence puede utilizarse no solo para visualizar
          ventas, sino para optimizar decisiones comerciales y capturar valor real.
        </p>

        <div class="impact-grid">
          <div class="impact">
            <h2>&darr;</h2>
            <p>Ventas con pérdida</p>
          </div>

          <div class="impact">
            <h2>&uarr;</h2>
            <p>Margen neto</p>
          </div>

          <div class="impact">
            <h2>&uarr;</h2>
            <p>Eficiencia comercial</p>
          </div>

          <div class="impact">
            <h2>&uarr;</h2>
            <p>Rentabilidad sostenible</p>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="badge">Strategic Recommendations</div>

        <h2 class="section-title">Plan de acción basado en analítica.</h2>

        <div class="grid-2">
          <div class="card">
            <h3>Pricing Intelligence</h3>
            <p>Implementar límites de descuento basados en margen y elasticidad de demanda.</p>
          </div>

          <div class="card">
            <h3>Portfolio Optimization</h3>
            <p>Priorizar productos y clientes con mayor contribución al beneficio.</p>
          </div>

          <div class="card">
            <h3>Value-Based Strategy</h3>
            <p>Reemplazar estrategias orientadas a volumen por decisiones orientadas a valor.</p>
          </div>

          <div class="card">
            <h3>Profit Monitoring</h3>
            <p>Monitorear rentabilidad y erosión de margen en tiempo real.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="galeria">
      <div class="container">
        <div class="badge">Dashboard Gallery</div>
        <h2 class="section-title">Visualización del dashboard del proyecto</h2>

        {
          dashboardShots.length > 0 ? (
            <div class="gallery-carousel" aria-label="Galería de dashboards Retail Decision Intelligence">
              {dashboardShots.map((img, index) => (
                <figure class={`shot-slide${index === 0 ? ' is-active' : ''}`} data-slide={index}>
                  <img
                    src={withBase(img)}
                    alt={`Dashboard Retail Decision Intelligence ${index + 1}`}
                    loading="lazy"
                  />
                </figure>
              ))}

              <button type="button" class="gallery-nav prev" id="gallery-prev" aria-label="Imagen anterior">
                &larr;
              </button>
              <button type="button" class="gallery-nav next" id="gallery-next" aria-label="Siguiente imagen">
                &rarr;
              </button>

              <div class="gallery-dots" id="gallery-dots">
                {dashboardShots.map((_, index) => (
                  <button
                    type="button"
                    class={`gallery-dot${index === 0 ? ' is-active' : ''}`}
                    data-dot={index}
                    aria-label={`Ir a imagen ${index + 1}`}
                  />
                ))}
              </div>
            </div>
          ) : (
            <p class="gallery-empty">
              Aún no hay imágenes cargadas. Agrega tus capturas en
              <strong> public/images/projects/superstore-360/</strong> con nombres como
              <strong> dashboard-1.jpg</strong>, <strong>dashboard-2.jpg</strong> o en formato PNG.
              También se aceptan archivos <strong>.jfif</strong> en
              <strong> public/images/projects/</strong> con nombres como <strong>clientes</strong>,
              <strong>desempeño/desempeno</strong>, <strong>producto</strong> y <strong>ventas</strong>.
            </p>
          )
        }
      </div>
    </section>

    <footer>
      <div class="container">
        <h2>Retail Decision Intelligence.</h2>

        <p>
          El verdadero problema no era vender más. Era capturar valor mediante decisiones comerciales
          inteligentes.
        </p>

        <div class="btn-group" style="justify-content:center;">
          <a
            href="https://github.com/DouglasAdonCa"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary">GitHub Repository</a
          >
          <a
            href="https://www.linkedin.com/in/douglas-adon-capellan-77a988103/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary">LinkedIn Project</a
          >
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .rdi-page {
    font-family: Inter, Arial, sans-serif;
    background: #020617;
    color: #e2e8f0;
    overflow-x: hidden;
  }

  :root {
    --primary: #2563eb;
    --secondary: #0f172a;
    --card: #111827;
    --border: #1e293b;
    --text: #cbd5e1;
    --muted: #94a3b8;
    --green: #10b981;
    --red: #ef4444;
    --orange: #f59e0b;
    --gradient: linear-gradient(135deg, #2563eb, #06b6d4);
  }

  .container {
    width: 90%;
    max-width: 1300px;
    margin: auto;
  }

  section {
    padding: 110px 0;
  }

  h1,
  h2,
  h3 {
    line-height: 1.05;
  }

  p {
    line-height: 1.8;
    color: var(--text);
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 24px;
    color: #93c5fd;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .back-link:hover {
    color: #dbeafe;
  }

  .badge {
    display: inline-block;
    padding: 8px 18px;
    border-radius: 50px;
    background: rgba(37, 99, 235, 0.1);
    border: 1px solid rgba(37, 99, 235, 0.3);
    color: #60a5fa;
    font-size: 14px;
    margin-bottom: 24px;
    letter-spacing: 1px;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.12), transparent 70%);
    top: -250px;
    right: -180px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  .hero h1 {
    font-size: 84px;
    font-weight: 800;
    margin-bottom: 30px;
    max-width: 920px;
  }

  .hero p {
    font-size: 20px;
    max-width: 760px;
    margin-bottom: 40px;
  }

  .btn-group {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 50px;
  }

  .btn {
    padding: 16px 28px;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 600;
    transition: 0.3s ease;
  }

  .btn-primary {
    background: var(--gradient);
    color: white;
  }

  .btn-secondary {
    background: #111827;
    border: 1px solid var(--border);
    color: white;
  }

  .btn:hover {
    transform: translateY(-4px);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .stat-card {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 24px;
  }

  .stat-card span {
    color: var(--muted);
    font-size: 13px;
    text-transform: uppercase;
  }

  .stat-card h3 {
    font-size: 34px;
    margin-top: 10px;
  }

  .dashboard-card {
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid var(--border);
    border-radius: 30px;
    padding: 30px;
    backdrop-filter: blur(20px);
  }

  .dashboard-top {
    display: flex;
    justify-content: space-between;
    color: #94a3b8;
    margin-bottom: 24px;
    font-size: 14px;
  }

  .dashboard-box {
    background: #020617;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 28px;
  }

  .dashboard-box h3 {
    font-size: 32px;
    margin-bottom: 16px;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-top: 25px;
  }

  .mini-box {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
  }

  .mini-box span {
    font-size: 12px;
    color: #94a3b8;
  }

  .mini-box h4 {
    font-size: 32px;
    margin-top: 10px;
  }

  .section-title {
    font-size: 60px;
    margin-bottom: 25px;
    max-width: 980px;
  }

  .section-sub {
    max-width: 850px;
    margin-bottom: 70px;
    font-size: 18px;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
  }

  .card {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 35px;
    transition: 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: rgba(37, 99, 235, 0.4);
  }

  .card h3 {
    font-size: 28px;
    margin-bottom: 20px;
  }

  .big-number {
    font-size: 72px;
    font-weight: 800;
    margin-bottom: 15px;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 50px;
  }

  .impact {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 35px;
    text-align: center;
  }

  .impact h2 {
    font-size: 52px;
    margin-bottom: 10px;
    color: white;
  }

  .impact p {
    color: var(--muted);
  }

  .pricing-card {
    border-radius: 28px;
    padding: 40px;
  }

  .loss {
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.3);
  }

  .profit {
    background: rgba(16, 185, 129, 0.08);
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .pricing-card span {
    text-transform: uppercase;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .loss span {
    color: var(--red);
  }

  .profit span {
    color: var(--green);
  }

  .pricing-value {
    font-size: 60px;
    font-weight: 800;
    margin: 20px 0;
  }

  .loss .pricing-value {
    color: var(--red);
  }

  .profit .pricing-value {
    color: var(--green);
  }

  .quote {
    background: #0f172a;
    border-left: 5px solid #2563eb;
    padding: 40px;
    border-radius: 20px;
    margin-top: 50px;
  }

  .quote h3 {
    font-size: 36px;
    line-height: 1.4;
  }

  .gallery-carousel {
    margin-top: 30px;
    position: relative;
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    background: #020617;
    min-height: min(72vh, 680px);
  }

  .shot-slide {
    display: none;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 0;
    margin: 0;
  }

  .shot-slide.is-active {
    display: block;
  }

  .shot-slide img {
    width: 100%;
    height: min(72vh, 680px);
    object-fit: contain;
    display: block;
    background: #020617;
  }

  .gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    border: 1px solid rgba(37, 99, 235, 0.5);
    background: rgba(2, 6, 23, 0.72);
    color: #dbeafe;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
    z-index: 3;
    transition: all 0.2s ease;
  }

  .gallery-nav:hover {
    background: rgba(37, 99, 235, 0.18);
    border-color: rgba(37, 99, 235, 0.9);
  }

  .gallery-nav.prev {
    left: 14px;
  }

  .gallery-nav.next {
    right: 14px;
  }

  .gallery-dots {
    position: absolute;
    left: 50%;
    bottom: 14px;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .gallery-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    border: 0;
    background: rgba(226, 232, 240, 0.35);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .gallery-dot.is-active {
    width: 24px;
    background: #2563eb;
  }

  .gallery-empty {
    border: 1px dashed rgba(37, 99, 235, 0.45);
    border-radius: 16px;
    padding: 24px;
    background: rgba(37, 99, 235, 0.06);
    margin-top: 24px;
  }

  footer {
    padding: 100px 0;
    border-top: 1px solid var(--border);
    text-align: center;
    margin-top: 80px;
  }

  footer h2 {
    font-size: 56px;
    margin-bottom: 20px;
  }

  footer p {
    max-width: 760px;
    margin: auto;
    margin-bottom: 40px;
  }

  @media (max-width: 1000px) {
    .hero-grid,
    .grid-2,
    .grid-3,
    .impact-grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 56px;
    }

    .section-title {
      font-size: 42px;
    }

    .stats {
      grid-template-columns: 1fr;
    }

    .gallery-carousel {
      min-height: 260px;
    }

    .shot-slide img {
      height: min(58vh, 420px);
    }

    .gallery-nav {
      width: 38px;
      height: 38px;
      font-size: 1rem;
    }
  }
</style>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('#galeria .shot-slide'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('#galeria .gallery-dot'));
  const carousel = document.querySelector<HTMLElement>('#galeria .gallery-carousel');
  const prevBtn = document.getElementById('gallery-prev');
  const nextBtn = document.getElementById('gallery-next');
  let idx = 0;
  let timer: ReturnType<typeof setInterval> | null = null;
  let touchStartX = 0;

  function paint(next: number) {
    if (slides.length === 0) return;
    idx = (next + slides.length) % slides.length;
    slides.forEach((slide, i) => slide.classList.toggle('is-active', i === idx));
    dots.forEach((dot, i) => dot.classList.toggle('is-active', i === idx));
  }

  function startAuto() {
    if (slides.length < 2) return;
    if (timer) clearInterval(timer);
    timer = setInterval(() => paint(idx + 1), 4200);
  }

  prevBtn?.addEventListener('click', () => {
    paint(idx - 1);
    startAuto();
  });

  nextBtn?.addEventListener('click', () => {
    paint(idx + 1);
    startAuto();
  });

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      paint(i);
      startAuto();
    });
  });

  carousel?.addEventListener(
    'touchstart',
    (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    },
    { passive: true }
  );

  carousel?.addEventListener('touchend', (e: TouchEvent) => {
    const deltaX = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(deltaX) < 40) return;
    if (deltaX < 0) paint(idx + 1);
    else paint(idx - 1);
    startAuto();
  });

  paint(0);
  startAuto();
</script>
