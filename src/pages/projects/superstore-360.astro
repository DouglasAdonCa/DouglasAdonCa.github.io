---
import Layout from '../../layouts/Layout.astro';
import { existsSync, readdirSync } from 'node:fs';
import { join, extname } from 'node:path';
import { withBase } from '../../lib/assetPath';

const title = 'Superstore 360 | Business Intelligence Analytics';
const description =
  'Caso de proyecto: solucion end-to-end de Business Intelligence para retail, enfocada en visibilidad ejecutiva, KPI Analytics y Decision Support.';

const dashboardDir = join(process.cwd(), 'public', 'images', 'projects', 'superstore-360');
const rootProjectsDir = join(process.cwd(), 'public', 'images', 'projects');
const allowedExtensions = new Set(['.png', '.jpg', '.jpeg', '.webp', '.jfif', '.jiff']);
const rootDashboardNames = new Set(['clientes', 'desempeno', 'desempeño', 'producto', 'ventas']);
const githubRawBase =
  'https://raw.githubusercontent.com/DouglasAdonCa/DouglasAdonCa.github.io/main/public/images/projects';

function readImages(dir: string, basePath: string, nameFilter?: Set<string>) {
  if (!existsSync(dir)) return [];
  return readdirSync(dir)
    .filter((name) => {
      if (!allowedExtensions.has(extname(name).toLowerCase())) return false;
      if (!nameFilter) return true;
      const baseName = name.replace(/\.[^.]+$/, '').toLowerCase();
      return nameFilter.has(baseName);
    })
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: 'base' }))
    .map((name) => `${basePath}/${name}`);
}

const localDashboardShots = [
  ...readImages(dashboardDir, '/images/projects/superstore-360'),
  ...readImages(rootProjectsDir, '/images/projects', rootDashboardNames),
];

const remoteDashboardShots = [
  `${githubRawBase}/clientes.jfif`,
  `${githubRawBase}/desempe%C3%B1o.jfif`,
  `${githubRawBase}/producto.jfif`,
  `${githubRawBase}/ventas.jfif`,
];

const dashboardShots = localDashboardShots.length > 0 ? localDashboardShots : remoteDashboardShots;
---

<Layout title={title} description={description}>
  <main class="s360-page">
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <a href="/#projects" class="back-link"><span aria-hidden="true">&larr;</span> Volver a proyectos</a>

          <div class="badge">BUSINESS INTELLIGENCE • RETAIL ANALYTICS</div>

          <h1>Descubriendo la historia oculta detras de los datos de retail.</h1>

          <p>
            Solucion end-to-end de Business Intelligence disenada para transformar datos
            transaccionales de retail en Operational Insights, visibilidad estrategica y Executive
            Decision-Making.
          </p>

          <div class="btn-group">
            <a href="#galeria" class="btn btn-primary">Ver Dashboard</a>
            <a href="#arquitectura" class="btn btn-secondary">Explorar Analytics</a>
          </div>

          <div class="stats">
            <div class="stat-card">
              <span>Business Intelligence</span>
              <h3>360 Visibility</h3>
            </div>

            <div class="stat-card">
              <span>Analytics</span>
              <h3>Executive KPIs</h3>
            </div>

            <div class="stat-card">
              <span>Enfoque retail</span>
              <h3>Decision Insights</h3>
            </div>
          </div>
        </div>

        <div class="dashboard-card">
          <div class="dashboard-top">
            <span>Retail Analytics Dashboard</span>
            <span>Executive View</span>
          </div>

          <div class="dashboard-box">
            <h3>Tendencia de rentabilidad identificada</h3>

            <p>
              El modelo analitico detecto una caida de rentabilidad en segmentos de producto
              seleccionados, a pesar del crecimiento sostenido de ventas en multiples regiones.
            </p>

            <div class="dashboard-grid">
              <div class="mini-box">
                <span>REVENUE</span>
                <h4>$12.4M</h4>
              </div>

              <div class="mini-box">
                <span>PROFIT</span>
                <h4>18.7%</h4>
              </div>

              <div class="mini-box">
                <span>ORDERS</span>
                <h4>54K</h4>
              </div>

              <div class="mini-box">
                <span>REGIONS</span>
                <h4>4</h4>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="container">
        <div class="badge">Business Challenge</div>

        <h2 class="section-title">
          Las empresas de retail generan grandes volumenes de datos pero poca visibilidad operacional.
        </h2>

        <p class="section-sub">
          Los sistemas transaccionales capturan ventas, clientes y operaciones de forma continua, pero
          sin una capa analitica estructurada se vuelve dificil identificar patrones, oportunidades y
          riesgos de negocio.
        </p>

        <div class="grid-3">
          <div class="card">
            <h3>Datos fragmentados</h3>
            <p>
              Ventas, clientes y metricas operacionales suelen quedar aislados en sistemas diferentes.
            </p>
          </div>

          <div class="card">
            <h3>Visibilidad limitada</h3>
            <p>
              Las organizaciones tienen dificultad para entender drivers de rentabilidad y tendencias
              operacionales.
            </p>
          </div>

          <div class="card">
            <h3>Decisiones reactivas</h3>
            <p>
              Las decisiones de negocio se toman con frecuencia sin contexto analitico ni Predictive
              Insights.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="arquitectura">
      <div class="container">
        <div class="badge">Analytics Architecture</div>

        <h2 class="section-title">De ventas transaccionales a inteligencia estrategica de negocio.</h2>

        <p class="section-sub">
          La solucion integra Data Transformation, KPI Modeling y Visual Analytics en un ecosistema
          centralizado de Decision Support.
        </p>

        <div class="pipeline">
          <div class="flow">
            <div class="flow-box">Retail Transactions</div>
            <div class="arrow">&rarr;</div>
            <div class="flow-box">Data Modeling</div>
            <div class="arrow">&rarr;</div>
            <div class="flow-box">KPI Analytics</div>
            <div class="arrow">&rarr;</div>
            <div class="flow-box">Executive Dashboards</div>
          </div>
        </div>
      </div>
    </section>

    <section>
      <div class="container split">
        <div>
          <div class="badge">Business Analytics</div>

          <h2 class="section-title">Data storytelling a traves de inteligencia analitica.</h2>

          <p>
            El proyecto explora comportamiento operacional, tendencias de rentabilidad y dinamicas de
            clientes para descubrir Strategic Insights ocultos en los datos transaccionales de retail.
          </p>
        </div>

        <div class="feature-list">
          <div class="feature">
            <h4>Profitability Analysis</h4>
            <p>
              Identificacion de categorias de producto y regiones que impulsan el desempeno del
              negocio.
            </p>
          </div>

          <div class="feature">
            <h4>Sales Intelligence</h4>
            <p>
              Executive KPIs que brindan visibilidad de revenue, orders y eficiencia operacional.
            </p>
          </div>

          <div class="feature">
            <h4>Customer Insights</h4>
            <p>
              Segmentacion analitica para revelar patrones de compra y oportunidades de negocio.
            </p>
          </div>

          <div class="feature">
            <h4>Visual Storytelling</h4>
            <p>
              Dashboards interactivos que transforman datos en narrativas estrategicas accionables.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="impacto">
      <div class="container">
        <div class="badge">Business Impact</div>

        <h2 class="section-title">Business Intelligence disenado para visibilidad estrategica.</h2>

        <div class="impact-grid">
          <div class="impact">
            <h2>&uarr;</h2>
            <p>Visibilidad operacional</p>
          </div>

          <div class="impact">
            <h2>&uarr;</h2>
            <p>Profitability Insights</p>
          </div>

          <div class="impact">
            <h2>&uarr;</h2>
            <p>Decision Support</p>
          </div>

          <div class="impact">
            <h2>&uarr;</h2>
            <p>Entendimiento del negocio</p>
          </div>
        </div>
      </div>
    </section>

    <section id="galeria">
      <div class="container">
        <div class="badge">Dashboard Gallery</div>
        <h2 class="section-title">Imagenes de dashboard del proyecto</h2>

        {
          dashboardShots.length > 0 ? (
            <div class="gallery-carousel" aria-label="Galeria de dashboards Superstore 360">
              {dashboardShots.map((img, index) => (
                <figure class={`shot-slide${index === 0 ? ' is-active' : ''}`} data-slide={index}>
                  <img src={withBase(img)} alt={`Dashboard Superstore 360 ${index + 1}`} loading="lazy" />
                </figure>
              ))}

              <button type="button" class="gallery-nav prev" id="gallery-prev" aria-label="Imagen anterior">
                &larr;
              </button>
              <button type="button" class="gallery-nav next" id="gallery-next" aria-label="Siguiente imagen">
                &rarr;
              </button>

              <div class="gallery-dots" id="gallery-dots">
                {dashboardShots.map((_, index) => (
                  <button
                    type="button"
                    class={`gallery-dot${index === 0 ? ' is-active' : ''}`}
                    data-dot={index}
                    aria-label={`Ir a imagen ${index + 1}`}
                  />
                ))}
              </div>
            </div>
          ) : (
            <p class="gallery-empty">
              Aun no hay imagenes cargadas. Agrega tus capturas en
              <strong> public/images/projects/superstore-360/</strong> con nombres como
              <strong> dashboard-1.jpg</strong>, <strong>dashboard-2.jpg</strong> o en formato PNG.
              Tambien se aceptan archivos <strong>.jfif</strong> en
              <strong> public/images/projects/</strong> con nombres como <strong>clientes</strong>,
              <strong>desempeno</strong>, <strong>producto</strong> y <strong>ventas</strong>.
            </p>
          )
        }
      </div>
    </section>

    <section>
      <div class="container">
        <div class="badge">Technology Stack</div>

        <h2 class="section-title">Tecnologias que impulsan el ecosistema analitico.</h2>

        <div class="grid-3">
          <div class="card">
            <h3>Data Analytics</h3>
            <p>SQL, Python, Pandas y workflows analiticos orientados a negocio.</p>
          </div>

          <div class="card">
            <h3>Business Intelligence</h3>
            <p>Dashboards en Power BI disenados para monitoreo ejecutivo y analisis de KPIs.</p>
          </div>

          <div class="card">
            <h3>Data Storytelling</h3>
            <p>
              Narrativas visuales que transforman datos de retail en insights estrategicos
              accionables.
            </p>
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div class="container">
        <h2>Retail Intelligence.</h2>

        <p>
          Superstore 360 transforma datos transaccionales de retail en visibilidad estrategica,
          ayudando a descubrir patrones operacionales y mejorar decisiones de negocio mediante
          analytics.
        </p>

        <div class="btn-group" style="justify-content:center;">
          <a
            href="https://github.com/DouglasAdonCa"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary">Repositorio en GitHub</a
          >
          <a
            href="https://www.linkedin.com/in/douglas-adon-capellan-77a988103/"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-secondary">Proyecto en LinkedIn</a
          >
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .s360-page {
    font-family: Inter, Arial, sans-serif;
    background: #020617;
    color: #e2e8f0;
    overflow-x: hidden;
  }

  :root {
    --primary: #8b5cf6;
    --secondary: #0f172a;
    --card: #111827;
    --border: #1e293b;
    --text: #cbd5e1;
    --muted: #94a3b8;
    --gradient: linear-gradient(135deg, #8b5cf6, #06b6d4);
  }

  .container {
    width: 90%;
    max-width: 1300px;
    margin: auto;
  }

  section {
    padding: 110px 0;
  }

  h1,
  h2,
  h3 {
    line-height: 1.05;
  }

  p {
    color: var(--text);
    line-height: 1.8;
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 24px;
    color: #c4b5fd;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .back-link:hover {
    color: #e9d5ff;
  }

  .badge {
    display: inline-block;
    padding: 8px 18px;
    border-radius: 50px;
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.3);
    color: var(--primary);
    font-size: 14px;
    margin-bottom: 24px;
    letter-spacing: 1px;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.12), transparent 70%);
    top: -250px;
    right: -180px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: center;
  }

  .hero h1 {
    font-size: 80px;
    font-weight: 800;
    margin-bottom: 30px;
    max-width: 900px;
  }

  .hero p {
    font-size: 20px;
    max-width: 720px;
    margin-bottom: 40px;
  }

  .btn-group {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 50px;
  }

  .btn {
    padding: 16px 28px;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 600;
    transition: 0.3s ease;
  }

  .btn-primary {
    background: var(--gradient);
    color: white;
  }

  .btn-secondary {
    background: #111827;
    border: 1px solid var(--border);
    color: white;
  }

  .btn:hover {
    transform: translateY(-4px);
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .stat-card {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 24px;
  }

  .stat-card span {
    font-size: 13px;
    color: var(--muted);
    text-transform: uppercase;
  }

  .stat-card h3 {
    font-size: 34px;
    margin-top: 10px;
  }

  .dashboard-card {
    background: rgba(15, 23, 42, 0.75);
    border: 1px solid var(--border);
    border-radius: 28px;
    padding: 30px;
    backdrop-filter: blur(20px);
  }

  .dashboard-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 24px;
    color: #94a3b8;
    font-size: 14px;
  }

  .dashboard-box {
    background: #020617;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 25px;
    margin-bottom: 20px;
  }

  .dashboard-box h3 {
    font-size: 30px;
    margin-bottom: 15px;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-top: 20px;
  }

  .mini-box {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
  }

  .mini-box span {
    color: #94a3b8;
    font-size: 12px;
  }

  .mini-box h4 {
    font-size: 30px;
    margin-top: 10px;
  }

  .section-title {
    font-size: 58px;
    margin-bottom: 25px;
    max-width: 950px;
  }

  .section-sub {
    max-width: 820px;
    margin-bottom: 70px;
    font-size: 18px;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
  }

  .card {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 35px;
    transition: 0.3s ease;
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: rgba(139, 92, 246, 0.4);
  }

  .card h3 {
    font-size: 28px;
    margin-bottom: 20px;
  }

  .pipeline {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 30px;
    padding: 60px;
    margin-top: 50px;
  }

  .flow {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .flow-box {
    flex: 1;
    min-width: 180px;
    background: #020617;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 30px;
    text-align: center;
  }

  .arrow {
    color: var(--primary);
    font-size: 32px;
  }

  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .feature-list {
    margin-top: 40px;
  }

  .feature {
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
  }

  .feature h4 {
    font-size: 22px;
    margin-bottom: 10px;
  }

  .impact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 50px;
  }

  .impact {
    background: #0f172a;
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: 30px;
    text-align: center;
  }

  .impact h2 {
    font-size: 44px;
    margin-bottom: 10px;
    background: var(--gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .gallery-carousel {
    margin-top: 30px;
    position: relative;
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    background: #020617;
    min-height: min(72vh, 680px);
  }

  .shot-slide {
    display: none;
    width: 100%;
    height: 100%;
  }

  .shot-slide.is-active {
    display: block;
  }

  .shot-slide {
    border: 0;
    border-radius: 0;
    margin: 0;
  }

  .shot-slide img {
    width: 100%;
    height: min(72vh, 680px);
    object-fit: contain;
    display: block;
    background: #020617;
  }

  .gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    border: 1px solid rgba(139, 92, 246, 0.5);
    background: rgba(2, 6, 23, 0.72);
    color: #e9d5ff;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    font-size: 1.2rem;
    font-weight: 700;
    cursor: pointer;
    z-index: 3;
    transition: all 0.2s ease;
  }
  .gallery-nav:hover {
    background: rgba(139, 92, 246, 0.18);
    border-color: rgba(139, 92, 246, 0.9);
  }
  .gallery-nav.prev {
    left: 14px;
  }
  .gallery-nav.next {
    right: 14px;
  }

  .gallery-dots {
    position: absolute;
    left: 50%;
    bottom: 14px;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 3;
  }

  .gallery-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    border: 0;
    background: rgba(226, 232, 240, 0.35);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .gallery-dot.is-active {
    width: 24px;
    background: #8b5cf6;
  }

  .shot-card {
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    background: #0b1220;
  }

  .shot-card img {
    width: 100%;
    height: 100%;
    min-height: 190px;
    object-fit: cover;
    display: block;
  }

  .gallery-empty {
    border: 1px dashed rgba(139, 92, 246, 0.45);
    border-radius: 16px;
    padding: 24px;
    background: rgba(139, 92, 246, 0.06);
    margin-top: 24px;
  }

  footer {
    padding: 100px 0;
    border-top: 1px solid var(--border);
    text-align: center;
    margin-top: 80px;
  }

  footer h2 {
    font-size: 56px;
    margin-bottom: 20px;
  }

  footer p {
    max-width: 760px;
    margin: auto;
    margin-bottom: 40px;
  }

  @media (max-width: 1000px) {
    .hero-grid,
    .split,
    .grid-3,
    .impact-grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 52px;
    }

    .section-title {
      font-size: 42px;
    }

    .stats {
      grid-template-columns: 1fr;
    }

    .flow {
      flex-direction: column;
    }

    .arrow {
      transform: rotate(90deg);
    }

    .gallery-carousel {
      min-height: 260px;
    }

    .shot-slide img {
      height: min(58vh, 420px);
    }

    .gallery-nav {
      width: 38px;
      height: 38px;
      font-size: 1rem;
    }
  }
</style>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('#galeria .shot-slide'));
  const dots = Array.from(document.querySelectorAll<HTMLElement>('#galeria .gallery-dot'));
  const carousel = document.querySelector<HTMLElement>('#galeria .gallery-carousel');
  const prevBtn = document.getElementById('gallery-prev');
  const nextBtn = document.getElementById('gallery-next');
  let idx = 0;
  let timer: ReturnType<typeof setInterval> | null = null;
  let touchStartX = 0;

  function paint(next: number) {
    if (slides.length === 0) return;
    idx = (next + slides.length) % slides.length;
    slides.forEach((slide, i) => slide.classList.toggle('is-active', i === idx));
    dots.forEach((dot, i) => dot.classList.toggle('is-active', i === idx));
  }

  function startAuto() {
    if (slides.length < 2) return;
    if (timer) clearInterval(timer);
    timer = setInterval(() => paint(idx + 1), 4200);
  }

  prevBtn?.addEventListener('click', () => {
    paint(idx - 1);
    startAuto();
  });
  nextBtn?.addEventListener('click', () => {
    paint(idx + 1);
    startAuto();
  });
  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      paint(i);
      startAuto();
    });
  });

  carousel?.addEventListener(
    'touchstart',
    (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
    },
    { passive: true }
  );

  carousel?.addEventListener('touchend', (e: TouchEvent) => {
    const deltaX = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(deltaX) < 40) return;
    if (deltaX < 0) paint(idx + 1);
    else paint(idx - 1);
    startAuto();
  });

  paint(0);
  startAuto();
</script>
